---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav';
import ContactForm from '../../components/ContactForm';
import { SUBJECT_PAGES } from '../../data/subjects';

const SITE_URL = 'https://insighttutors.com.au';
---

<BaseLayout
  title="Subjects We Teach | Insight Tutors"
  description="VCE Maths and English tutoring in Melbourne. Mathematical Methods, Specialist Maths, General Maths, English, English Literature, English Language, and Years 1–10."
  canonicalUrl={`${SITE_URL}/subjects`}
>
  <Nav client:load />

  <main class="pt-[87px]">
    <section class="mx-auto w-full max-w-5xl px-5 md:px-16 py-16 md:py-24">
      <h1 class="insight-heading text-4xl font-medium leading-[1.05] tracking-tight md:text-5xl">
        Subjects We Teach
      </h1>
      <p class="mt-4 max-w-xl text-xl leading-relaxed text-[#6B6867]">
        We specialise in VCE Mathematics and VCE English, the two subjects where expert one-on-one support makes the biggest difference to an ATAR.
      </p>

      <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2">
        {SUBJECT_PAGES.map((subject) => (
          <a
            href={`/subjects/${subject.slug}`}
            class="group flex flex-col rounded-2xl border border-[#E2DFDB] bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.08)]"
          >
            <span class="text-xs font-semibold uppercase tracking-widest text-[#8EAF8A]">
              {subject.slug === "maths" ? "VCE + Years 1–10" : "VCE + Years 7–10"}
            </span>
            <h2 class="insight-heading mt-3 text-3xl font-medium text-[#1A1615]">{subject.title}</h2>
            <p class="mt-3 text-base leading-relaxed text-[#555551]">{subject.subheadline}</p>

            <ul class="mt-6 space-y-2">
              {subject.coverItems.map((item) => (
                <li class="flex items-center gap-2 text-sm text-[#555551]">
                  <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-[#F0744A]" />
                  {item.title}
                </li>
              ))}
            </ul>

            <span class="mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-[#F0744A] transition-opacity group-hover:opacity-70">
              Learn more →
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-[#E2DFDB] bg-[#F4F4F2]">
      <div class="mx-auto w-full max-w-3xl px-5 py-16 text-center">
        <h2 class="insight-heading text-3xl font-medium leading-[1.05] tracking-tight md:text-4xl">
          Not sure which subject you need?
        </h2>
        <p class="mx-auto mt-4 max-w-lg text-xl leading-relaxed text-[#6B6867]">
          Book a free trial and we'll match your student with the right tutor.
        </p>
        <a href="#contact" class="mt-8 inline-block liquid-glass-light rounded-full px-7 py-3.5 text-sm ring-1 ring-black/20 transition-opacity hover:opacity-75 active:scale-[0.98]">
          Book a free class
        </a>
      </div>
    </section>

    <section id="contact" class="bg-[#F4F4F2]">
      <div class="mx-auto flex w-full max-w-2xl flex-col items-center px-5 py-16 md:py-20">
        <ContactForm client:load />
      </div>
    </section>
  </main>

  <footer class="bg-[#1A1615]">
    <div class="mx-auto w-full max-w-6xl px-5 md:px-16 py-8">
      <p class="text-base font-semibold text-white">Insight Tutors</p>
      <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/60">
        <li><a href="/" class="transition-colors hover:text-white">Home</a></li>
        <li><a href="/tutors" class="transition-colors hover:text-white">Our Tutors</a></li>
        <li><a href="/subjects" class="transition-colors hover:text-white">Subjects</a></li>
        <li><a href="/pricing" class="transition-colors hover:text-white">Pricing</a></li>
        <li><a href="#contact" class="transition-colors hover:text-white">Contact</a></li>
      </ul>
    </div>
  </footer>
</BaseLayout>
